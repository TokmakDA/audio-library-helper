{
  "manifest_version": 3,
  "name": "Audio Library Helper",
  "version": "1.1.0",
  "description": "Инструмент для экспорта аудиотреков в личную библиотеку",
  "icons": {
    "16": "icons/app-icon.png",
    "32": "icons/app-icon.png",
    "48": "icons/app-icon.png",
    "128": "icons/app-icon.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/app-icon.png",
      "32": "icons/app-icon.png",
      "48": "icons/app-icon.png",
      "128": "icons/app-icon.png"
    },
    "default_popup": "html/popup.html",
    "default_title": "Audio Library Helper"
  },
  "background": {
    "scripts": [
      "js/config.js",
      "html/bs5/browser-id3-writer.6.0.0.mjs",
      "js/service_worker.js"
    ],
    "service_worker": "js/service_worker.js",
    "type": "classic"
  },
  "content_scripts": [
    {
      "matches": [
        "https://api.music.yandex.ru/*",
        "https://next.music.yandex.com/*",
        "https://next.music.yandex.ru/*",
        "https://next.music.yandex.kz/*",
        "https://next.music.yandex.by/*",
        "https://next.music.yandex.uz/*",
        "https://*.strm.yandex.net/*",
        "https://music.yandex.ru/*",
        "https://music.yandex.com/*",
        "https://music.yandex.kz/*",
        "https://music.yandex.by/*",
        "https://music.yandex.uz/*",
        "https://yastatic.net/*"
      ],
      "js": ["js/config.js", "js/content.js"]
    }
  ],
  "permissions": [
    "tabs",
    "downloads",
    "webRequest",
    "scripting",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.music.yandex.ru/*",
    "https://api.music.yandex.ru/*",
    "https://*.strm.yandex.net/*",
    "https://*.yandex.net/*",
    "https://*.yandex.ru/*"
  ],
  "options_page": "html/options.html",
  "browser_specific_settings": {
    "gecko": {
      "id": "audio-library-helper@local"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["js/config.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
