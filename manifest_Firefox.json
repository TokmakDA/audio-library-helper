{
  "manifest_version": 2,
  "name": "Audio Library Helper",
  "version": "1.0.1",
  "description": "Инструмент для экспорта аудиотреков в личную библиотеку",
  "icons": {
    "128": "icons/app-icon.png"
  },
  "action": {
    "default_icon": "icons/app-icon.png",
    "default_popup": "html/popup.html",
    "default_title": "Audio Library Helper"
  },
  "background": {
    "scripts": ["js/service_worker.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://api.music.yandex.ru/*",
        "https://next.music.yandex.com/*",
        "https://next.music.yandex.kz/*",
        "https://next.music.yandex.by/*",
        "https://next.music.yandex.uz/*",
        "https://*.strm.yandex.net/*",
        "https://music.yandex.ru/*",
        "https://music.yandex.com/*",
        "https://music.yandex.kz/*",
        "https://music.yandex.by/*",
        "https://music.yandex.uz/*",
        "https://yastatic.net/*"
      ],
      "js": ["js/config.js", "js/content.js"]
    }
  ],
  "permissions": [
    "tabs",
    "downloads",
    "webRequest",
    "scripting",
    "activeTab",
    "storage",
    "https://api.music.yandex.ru/*",
    "https://*.strm.yandex.net/*",
    "https://*.yandex.net/*",
    "https://*.yandex.ru/*"
  ],
  "host_permissions": [
    "https://*.music.yandex.ru/*",
    "https://api.music.yandex.ru/*",
    "https://*.strm.yandex.net/*",
    "https://*.yandex.net/*",
    "https://*.yandex.ru/*"
  ],
  "incognito": "split",
  "options_page": "html/options.html"
}
